{
  "name": "react-hooks-project-pack",
  "private": true,
  "version": "1.0.0",
  "description": "8 standalone hook-focused React apps, one per folder (Vite + React 18)",
  "workspaces": [
    "01-counter",
    "02-todo",
    "03-stopwatch",
    "04-color-picker",
    "05-digital-clock",
    "06-character-counter",
    "07-weather",
    "08-recipe"
  ],
  "scripts": {
    "dev:counter": "npm run dev -w 01-counter",
    "dev:todo": "npm run dev -w 02-todo",
    "dev:stopwatch": "npm run dev -w 03-stopwatch",
    "dev:color-picker": "npm run dev -w 04-color-picker",
    "dev:digital-clock": "npm run dev -w 05-digital-clock",
    "dev:character-counter": "npm run dev -w 06-character-counter",
    "dev:weather": "npm run dev -w 07-weather",
    "dev:recipe": "npm run dev -w 08-recipe",
    "build:all": "npm run build --workspaces"
  }
}
